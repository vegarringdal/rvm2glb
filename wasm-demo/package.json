{
  "name": "rvm2glb-wasm-demo",
  "private": true,
  "version": "0.2.0",
  "type": "module",
  "scripts": {
    "build:wasm": "wasm-pack build ../crates/wasm --target web --out-dir ../../wasm-demo/pkg --release",
    "build:wasm:opt": "wasm-pack build ../crates/wasm --target web --out-dir ../../wasm-demo/pkg --release -- --features optimize",
    "dev": "npm run build:wasm && vite",
    "build": "npm run build:wasm && vite build",
    "build:pages": "VITE_BASE=/rvm2glb/ npm run build",
    "preview": "vite preview",
    "preview:pages": "VITE_BASE=/rvm2glb/ vite preview --base /rvm2glb/",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "fflate": "^0.8.2"
  },
  "devDependencies": {
    "typescript": "^6.0.0",
    "vite": "8.0.16"
  }
}
